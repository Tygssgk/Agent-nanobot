
{
  "providers": {
    "openai": {
      "apiKey": "${LITELLM_MASTER_KEY}",
      "apiBase": "${LITELLM_PROXY_URL}"
    }
  },
  "agents": {
    "default": {
      "provider": "openai",
      "model": "gemini-flash"
    },
    "pro": {
      "provider": "openai",
      "model": "gemini-pro"
    },
    "fast": {
      "provider": "openai",
      "model": "groq-fast"
    }
  }
}
